    "eslint": "^10.5.0",
    "prisma": "^7.8.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "argon2": "^0.44.0"
  }
