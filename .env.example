# Plantilla de variables de entorno. Copia este archivo a .env y ajusta los valores.
# .env NO se versiona (.gitignore); .env.example SI, siempre sin credenciales reales.
#
# Conexion a PostgreSQL. En desarrollo, Postgres corre en el contenedor Docker
# ipd-postgres (ver ADR-001):
#   docker run --name ipd-postgres -e POSTGRES_PASSWORD=<tu-password> -e POSTGRES_DB=ipd -p 5432:5432 -d postgres:17
DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:5432/ipd?schema=public"

# Servidor HTTP local.
PORT=3000
NODE_ENV=development
SESSION_SECRET="CHANGE_ME_SESSION_SECRET_MIN_32_CHARS"